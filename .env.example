# Environment Configuration Template
# For development: Copy to .env and fill in your values
# For production: Set these as environment variables in Render dashboard

# ===========================
# STREAMLIT CONFIGURATION
# ===========================

# Local Development (set to false for local development)
STREAMLIT_SERVER_HEADLESS=true

# Server Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=false

# Logging
STREAMLIT_LOGGER_LEVEL=info

# Client Settings
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=false
STREAMLIT_CLIENT_TOOLBAR_MODE=viewer

# Browser
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ===========================
# TENSORFLOW CONFIGURATION
# ===========================

TF_CPP_MIN_LOG_LEVEL=3
TF_USE_LEGACY_KERAS=1

# ===========================
# PYTHON CONFIGURATION
# ===========================

PYTHONUNBUFFERED=1
PYTHONHASHSEED=0

# ===========================
# APPLICATION PATHS
# ===========================

MODEL_PATH=models/final_model.sav
CNN_MODEL_PATH=models/keras_model.h5
DATASET_PATH=datasets/
IMAGES_PATH=images/
CTSCAN_PATH=ctscan_images/

# ===========================
# DOCKER CONFIGURATION
# ===========================

DOCKER_REGISTRY=docker.io
DOCKER_IMAGE=lung-cancer-detection
DOCKER_TAG=latest

# ===========================
# RENDER CONFIGURATION
# ===========================

RENDER_SERVICE_NAME=lung-cancer-detection
RENDER_REGION=oregon

# ===========================
# DEVELOPMENT SETTINGS
# ===========================

DEBUG=false
TESTING=false

# Cache Settings (local development)
STREAMLIT_CACHE_MAX_ENTRIES=1000
STREAMLIT_CACHE_TTL=3600

# Optional: For API/Webhook (if needed)
# API_KEY=your_api_key_here
# WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Database (if adding database support)
# DATABASE_URL=sqlite:///./app.db
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=lung_cancer_db
# DATABASE_USER=dbuser
# DATABASE_PASSWORD=dbpass

# ===========================
# NOTES
# ===========================
# - For local development: Create .env from this template
# - For Docker: Environment variables are set in Dockerfile and docker-compose.yml
# - For Render: Environment variables are set in Render dashboard
# - Never commit .env file with sensitive data
# - Always add .env to .gitignore

